    <body>
        <Background />
        <div class="h-screen snap-y snap-mandatory snap-always overflow-auto scroll-smooth" id="content">
            <Section>
                <h1 class="font-serif text-8xl font-semibold">Riley Flynn</h1>
                <div>Cloud Developer</div>
            </Section>
            <Section>
                <h1 class="font-serif text-8xl font-semibold">I'm a second div</h1>
                <div>Here's some text!</div>
